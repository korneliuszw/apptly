{
	"$schema": "https://turborepo.dev/schema.json",
	"globalDependencies": [".env"],
	"globalEnv": ["DATABASE_URL", "BETTER_AUTH_URL", "BETTER_AUTH_SECRET"],
	"tasks": {
		"build": {
			"inputs": [
				"$TURBO_DEFAULT$",
				".env"
			],
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"inputs": [
				"$TURBO_DEFAULT$",
				".env"
			],
			"persistent": true,
			"cache": false
		}
	}
}
