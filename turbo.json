{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"env": ["DATABASE_URL", "BETTER_AUTH_URL", "BETTER_AUTH_SECRET"],
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"env": ["DATABASE_URL", "BETTER_AUTH_URL", "BETTER_AUTH_SECRET"],
			"persistent": true,
			"cache": false
		}
	}
}
