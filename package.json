{
	"name": "@apptly/source",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"dev": "dotenvx run -- turbo dev",
		"dev:backend": "dotenvx run -- bun --elide-lines 0 --filter @apptly/backend dev",
		"dev:frontend": "dotenvx run -- bun --filter @apptly/web dev",
		"seed": "dotenvx run -- bun --filter @apptly/seed seed",
		"db-setup": "dotenvx run -- bun --filter @apptly/db db:push"
	},
	"private": true,
	"dependencies": {
		"@dotenvx/dotenvx": "^1.58.0",
		"@elysiajs/openapi": "^1.4.14",
		"better-auth": "^1.5.6",
		"dockerode": "^4.0.10",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"drizzle-typebox": "^0.3.3",
		"elysia": "^1.4.28",
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@playwright/test": "^1.36.0",
		"@swc-node/register": "1.11.1",
		"@swc/core": "1.15.8",
		"@swc/helpers": "0.5.18",
		"@swc/jest": "~0.2.38",
		"@testing-library/dom": "10.4.0",
		"@testing-library/react": "16.3.0",
		"@types/bun": "^1.3.11",
		"@types/jest": "^30.0.0",
		"@types/node": "20.19.9",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"jest": "^30.0.2",
		"jest-environment-node": "^30.0.2",
		"jest-util": "^30.0.2",
		"jiti": "2.4.2",
		"nx": "22.6.1",
		"postcss": "8.4.38",
		"prettier": "^2.6.2",
		"tailwindcss": "3.4.3",
		"ts-jest": "^29.4.0",
		"ts-node": "10.9.1",
		"tslib": "^2.3.0",
		"tsx": "^4.21.0",
		"turbo": "^2.8.20",
		"typescript": "~5.9.2"
	},
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"overrides": {
		"@sinclair/typebox": "0.34.0"
	},
	"packageManager": "bun@1.3.10"
}
